        "Eliminar dominio remoto padrao",
        "Criar fallback local/offline"
      ]
    },
    {
      "ordem": 3,
      "titulo": "Desativacao controlada de recursos remotos",
      "itens": [
        "Terminal remoto",
        "Preview remoto",
